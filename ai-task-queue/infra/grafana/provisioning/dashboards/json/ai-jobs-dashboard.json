{
  "dashboard": {
    "title": "AI Job Queue Dashboard",
    "tags": ["ai", "jobs", "queue"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Jobs Received (Rate)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(worker_jobs_received_total[5m])",
            "legendFormat": "Jobs/sec",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "jobs/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "Job Success vs Failure",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(worker_jobs_succeeded_total[5m])",
            "legendFormat": "Success",
            "refId": "A"
          },
          {
            "expr": "rate(worker_jobs_failed_total[5m])",
            "legendFormat": "Failed",
            "refId": "B"
          }
        ]
      },
      {
        "id": 3,
        "title": "Processing Duration (p50, p95, p99)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(worker_jobs_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(worker_jobs_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(worker_jobs_processing_duration_seconds_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "duration"},
          {"format": "short"}
        ]
      },
      {
        "id": 4,
        "title": "Total Jobs (Cumulative)",
        "type": "stat",
        "gridPos": {"x": 12, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "worker_jobs_received_total",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 5,
        "title": "Error Rate (%)",
        "type": "stat",
        "gridPos": {"x": 18, "y": 8, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "(rate(worker_jobs_failed_total[5m]) / rate(worker_jobs_received_total[5m])) * 100",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 10, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Service Health",
        "type": "stat",
        "gridPos": {"x": 12, "y": 12, "w": 12, "h": 4},
        "targets": [
          {
            "expr": "up{job=\"core-service\"}",
            "legendFormat": "Core",
            "refId": "A"
          },
          {
            "expr": "up{job=\"worker-service\"}",
            "legendFormat": "Worker",
            "refId": "B"
          },
          {
            "expr": "up{job=\"api-gateway\"}",
            "legendFormat": "Gateway",
            "refId": "C"
          }
        ],
        "options": {
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "value": "1", "text": "UP", "color": "green"},
              {"type": "value", "value": "0", "text": "DOWN", "color": "red"}
            ]
          }
        }
      }
    ],
    "refresh": "10s",
    "time": {"from": "now-1h", "to": "now"},
    "timepicker": {},
    "schemaVersion": 27,
    "version": 1
  }
}
